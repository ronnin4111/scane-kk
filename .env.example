# ============================================
# KK Scan - Environment Variables
# ============================================
# Copy this file to .env.local (or .env) and fill in the values.
# NEVER commit .env.local to version control!

# ---- AI API Keys ----

# Z.AI API (PRIMARY OCR Vision Provider)
# Get API key at: https://chat.z.ai → Settings → API Keys
# Model used: glm-4.6v-flash (FREE, 128k context, support image input)
# Endpoint: https://api.z.ai/api/paas/v4/chat/completions
ZAI_BASE_URL=https://api.z.ai/api
ZAI_API_KEY=your-zai-api-key-here

# Google Gemini API (FALLBACK - used if Z.AI fails)
# Get free key at: https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1500 requests/day for gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Database ----
# SQLite (local development)
DATABASE_URL=file:./db/custom.db

# ---- Next.js ----
# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# ---- App Settings (Optional) ----
# Maximum file size for upload (in MB, default 10)
# MAX_FILE_SIZE_MB=10

# OCR timeout (in seconds, default 120)
# OCR_TIMEOUT_SECONDS=120
